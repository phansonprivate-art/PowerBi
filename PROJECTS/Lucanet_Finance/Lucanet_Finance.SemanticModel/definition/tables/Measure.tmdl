	measure 'GuV Ist ACT' = CALCULATE([GuV Ist])
		displayFolder: Time Intelligence\01 Current Period
		lineageTag: 1c5f1136-8a33-424a-8993-95e0cf40a6a8

	measure 'GuV Ist LY' = CALCULATE([GuV Ist], SAMEPERIODLASTYEAR('Datum'[Datum]))
		displayFolder: Time Intelligence\02 Last Year
		lineageTag: 518adbaa-1ca0-4a8b-96fb-d8cb762989e4

	measure 'GuV Ist Delta' = [GuV Ist ACT] - [GuV Ist LY]
		displayFolder: Time Intelligence\03 YoY Variance (Monthly)
		lineageTag: 54e4924e-4b30-4d4e-9dd8-74f206ae9d2b

	measure 'GuV Ist Delta %' = DIVIDE([GuV Ist Delta], [GuV Ist LY])
		formatString: 0.00%
		displayFolder: Time Intelligence\03 YoY Variance (Monthly)
		lineageTag: db0b1c6f-c762-4b8f-920f-d7667a001795

	measure 'GuV Ist YTD' =
			
			CALCULATE(
			    [GuV Ist],
			    DATESYTD('Datum'[Datum]),
			    'Datum'[Datum] <= TODAY(),
			    REMOVEFILTERS('Datum'[Jahr])
			)
		displayFolder: Time Intelligence\04 YTD
		lineageTag: aa401cc9-6487-4b8a-9d01-bd7926584c04

	measure 'GuV Ist LYTD' =
			
			CALCULATE(
			    [GuV Ist],
			    FILTER(
			        SAMEPERIODLASTYEAR(DATESYTD('Datum'[Datum])),
			        'Datum'[Datum] <= EDATE(TODAY(), -12)
			    ),
			    REMOVEFILTERS('Datum'[Jahr])
			)
		displayFolder: Time Intelligence\05 LYTD
		lineageTag: ad6da810-fc34-4032-8705-7ddf884e3a38

	measure 'GuV Ist YTD Total' =
			VAR _Heute = TODAY()
			VAR _ZeilenDatum = MAX('Datum'[Datum])
			RETURN IF(_ZeilenDatum <= _Heute, [GuV Ist YTD], BLANK())
		displayFolder: Time Intelligence\06 YTD Total
		lineageTag: 33d60c05-4bc2-4659-85c7-6d82263dc421

	measure 'GuV Ist LYTD Total' =
