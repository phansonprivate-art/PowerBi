table Measure
	lineageTag: 97de4db7-de36-4438-b9f4-f62ce16565e8

	/// Migriert aus Qlik: Sum({<MASTER_CAL.Date 2025, AccountLevel1='GuV', AccountLevel2='Operatives Ergebnis', DataLevelName='Plan'>} FACTS.Value)
	measure 'GuV Plan Operatives Ergebnis' =
			CALCULATE(
			    SUM(Facts[Value]),
			    AccountStructure[AccountLevel1] = "GuV",
			    AccountStructure[AccountLevel2] = "Operatives Ergebnis",
			    DataLevel[DataLevelName] = "Plan"
			)
		formatString: #,##0.00
		displayFolder: Standard
		lineageTag: 652b6aed-d585-485d-8f81-bc4fb675d95f

	measure 'GuV Ist Operatives Ergebnis' =
			CALCULATE(
			    SUM(Facts[Value]),
			    AccountStructure[AccountLevel1] = "GuV",
			    AccountStructure[AccountLevel2] = "Operatives Ergebnis",
			    DataLevel[DataLevelName] = "Ist"
			)
		formatString: 0
		displayFolder: Standard
		lineageTag: a1155a90-c605-46b3-a5f7-cfb7f27c1907

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'GuV Ist' =
			CALCULATE(
			    SUM(Facts[Value]),
			    AccountStructure[AccountLevel1] = "GuV",
